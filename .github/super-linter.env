# Super-Linter Configuration — local Docker runs
# The CI workflow (.github/workflows/super-linter.yml) defines its own
# VALIDATE_* env vars inline; this file is consumed only by the local
# run scripts (scripts/local-super-linter.sh, scripts/linting/run_super_linter.sh).

DEFAULT_BRANCH=main
LINTER_RULES_PATH=.github/linters
MARKDOWN_CONFIG_FILE=.markdownlint.yml

VALIDATE_BASH=true
VALIDATE_BASH_EXEC=true
VALIDATE_CHECKOV=true
VALIDATE_EDITORCONFIG=true
VALIDATE_ENV=true
VALIDATE_GITHUB_ACTIONS=true
VALIDATE_GITLEAKS=true
VALIDATE_JSCPD=true
VALIDATE_JSON=true
VALIDATE_JSONC=true
VALIDATE_MARKDOWN=true
VALIDATE_POWERSHELL=true
VALIDATE_PYTHON_RUFF=true
VALIDATE_PYTHON_RUFF_FORMAT=true
VALIDATE_SHELL_SHFMT=true
VALIDATE_YAML=true
